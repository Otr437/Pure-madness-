import {
  SmartContract,
  method,
  state,
  State,
  PublicKey,
  Field,
  Permissions,
  UInt64,
  Bool,
  Struct,
} from 'o1js';

export class Record extends Struct({
  id: Field,
  value: UInt64,
  timestamp: UInt64,
  active: Bool,
}) {}

export class AdvancedContract extends SmartContract {
  @state(PublicKey) owner = State<PublicKey>();
  @state(Field) recordHash = State<Field>();
  @state(UInt64) totalRecords = State<UInt64>();
  @state(Bool) paused = State<Bool>();

  async deploy() {
    await super.deploy();
    this.account.permissions.set({
      ...Permissions.default(),
      setVerificationKey: Permissions.VerificationKey.impossibleDuringCurrentVersion(),
      setPermissions: Permissions.impossible(),
    });
    
    this.owner.set(this.sender.getAndRequireSignature());
    this.recordHash.set(Field(0));
    this.totalRecords.set(UInt64.from(0));
    this.paused.set(Bool(false));
  }

  @method async addRecord(record: Record) {
