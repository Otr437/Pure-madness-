ask_yes_no() {
    local prompt="$1"
    local default="${2:-n}"
    while true; do
        if [ "$default" = "y" ]; then
            read -p "${prompt} [Y/n]: " response
            response=${response:-y}
        else
            read -p "${prompt} [y/N]: " response
            response=${response:-n}
        fi
        case "$response" in
            [Yy]*) return 0 ;;
            [Nn]*) return 1 ;;
            *) echo -e "${RED}Please answer yes or no.${NC}" ;;
        esac
    done
}

log_success() { echo -e "${GREEN}✓ $1${NC}"; }
