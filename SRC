import { Mina, PrivateKey, AccountUpdate, fetchAccount } from 'o1js';
import fs from 'fs';
import path from 'path';

interface DeployConfig {
  network: string;
  contractName: string;
  feePayerKey: string;
}

async function deploy() {
  const configPath = process.argv[2];
  if (!configPath) {
    console.error('Usage: ts-node deploy.ts <config-path>');
    process.exit(1);
  }

  const config: DeployConfig = JSON.parse(fs.readFileSync(configPath, 'utf8'));
  const networkConfigPath = path.join(__dirname, '../../NETWORKS', config.network, 'config.json');
  const networkConfig = JSON.parse(fs.readFileSync(networkConfigPath, 'utf8'));

  console.log(`\n🚀 Deploying to ${networkConfig.name}`);
  console.log(`   Network: ${config.network}`);
  console.log(`   Contract: ${config.contractName}\n`);

  const Network = Mina.Network({
    mina: networkConfig.url,
    archive: networkConfig.archive,
  });
  Mina.setActiveInstance(Network);

  const feePayerKey = PrivateKey.fromBase58(config.feePayerKey);
  const feePayerAddress = feePayerKey.toPublicKey();

  console.log(`Fee payer: ${feePayerAddress.toBase58()}`);
  await fetchAccount({ publicKey: feePayerAddress });

  const contractPath = path.join(__dirname, '../../DEPLOY_READY', config.contractName);
  const { default: Contract } = await import(contractPath);

  const contractKey = PrivateKey.random();
  const contractAddress = contractKey.toPublicKey();

  console.log(`\nContract address: ${contractAddress.toBase58()}`);
  console.log('\n⏳ Compiling contract...');
  
  await Contract.compile();
  console.log('✓ Compilation complete');

  console.log('\n⏳ Creating deploy transaction...');
  const tx = await Mina.transaction(
    { sender: feePayerAddress, fee: Number(networkConfig.defaultFee) * 1e9 },
    async () => {
      AccountUpdate.fundNewAccount(feePayerAddress);
      await Contract.deploy();
    }
  );

  await tx.prove();
  const sentTx = await tx.sign([feePayerKey, contractKey]).send();

  console.log('✓ Transaction sent');

  const deploymentInfo = {
    network: config.network,
    contractName: config.contractName,
    contractAddress: contractAddress.toBase58(),
    contractKey: contractKey.toBase58(),
    feePayerAddress: feePayerAddress.toBase58(),
    timestamp: new Date().toISOString(),
    transactionHash: sentTx.hash,
    explorerUrl: `${networkConfig.explorerUrl}/tx/${sentTx.hash}`,
  };

  const deploymentPath = path.join(__dirname, '../../DEPLOYED', config.network, `${config.contractName}_${Date.now()}.json`);
  fs.writeFileSync(deploymentPath, JSON.stringify(deploymentInfo, null, 2));

  console.log('\n✅ DEPLOYMENT SUCCESSFUL\n');
  console.log(`Contract: ${contractAddress.toBase58()}`);
  console.log(`Explorer: ${deploymentInfo.explorerUrl}`);
  console.log(`Deployment info saved: ${deploymentPath}\n`);
}

deploy().catch((err) => {
  console.error('\n❌ Deployment failed:', err);
  process.exit(1);
});
EOF

