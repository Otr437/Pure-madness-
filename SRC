// SPDX-License-Identifier: MIT
pragma solidity ^0.8.24;

import "@openzeppelin/contracts/access/AccessControl.sol";
import "@openzeppelin/contracts/utils/ReentrancyGuard.sol";
import "@openzeppelin/contracts/utils/Pausable.sol";

contract AdvancedContract is AccessControl, ReentrancyGuard, Pausable {
    bytes32 public constant ADMIN_ROLE = keccak256("ADMIN_ROLE");
    bytes32 public constant OPERATOR_ROLE = keccak256("OPERATOR_ROLE");
    
    struct Record {
        uint256 id;
        uint256 value;
        uint256 timestamp;
        address creator;
        bool active;
    }
    
    mapping(uint256 => Record) public records;
    uint256 public totalRecords;
    
    event RecordCreated(uint256 indexed id, uint256 value, address indexed creator);
    event RecordUpdated(uint256 indexed id, uint256 newValue);
    event RecordDeactivated(uint256 indexed id);
    
    constructor() {
        _grantRole(DEFAULT_ADMIN_ROLE, msg.sender);
        _grantRole(ADMIN_ROLE, msg.sender);
        _grantRole(OPERATOR_ROLE, msg.sender);
    }
    
    function createRecord(uint256 _value) external onlyRole(OPERATOR_ROLE) whenNotPaused returns (uint256) {
        uint256 recordId = totalRecords++;
        
        records[recordId] = Record({
            id: recordId,
            value: _value,
            timestamp: block.timestamp,
            creator: msg.sender,
            active: true
        });
        
        emit RecordCreated(recordId, _value, msg.sender);
        return recordId;
    }
    
    function updateRecord(uint256 _id, uint256 _newValue) external onlyRole(OPERATOR_ROLE) whenNotPaused {
        require(records[_id].active, "Record not active");
        records[_id].value = _newValue;
        records[_id].timestamp = block.timestamp;
        emit RecordUpdated(_id, _newValue);
    }
    
    function deactivateRecord(uint256 _id) external onlyRole(ADMIN_ROLE) {
        require(records[_id].active, "Record already inactive");
        records[_id].active = false;
        emit RecordDeactivated(_id);
    }
    
    function pause() external onlyRole(ADMIN_ROLE) {
        _pause();
    }
    
    function unpause() external onlyRole(ADMIN_ROLE) {
        _unpause();
    }
    
    function getRecord(uint256 _id) external view returns (Record memory) {
        return records[_id];
    }
}
EOF

