// SPDX-License-Identifier: MIT
pragma solidity ^0.8.24;

import "@openzeppelin/contracts/access/Ownable.sol";
import "@openzeppelin/contracts/utils/ReentrancyGuard.sol";
import "@openzeppelin/contracts/utils/Pausable.sol";

contract BasicContract is Ownable, ReentrancyGuard, Pausable {
    uint256 public value;
    uint256 public counter;
    
    event ValueUpdated(uint256 indexed oldValue, uint256 indexed newValue, address indexed updater);
    event CounterIncremented(uint256 indexed newCounter);
    
    error SameValue();
    error ZeroValue();
    
    constructor(uint256 _initialValue) Ownable(msg.sender) {
        if (_initialValue == 0) revert ZeroValue();
        value = _initialValue;
        counter = 0;
    }
    
    function updateValue(uint256 _newValue) external whenNotPaused nonReentrant {
        if (_newValue == value) revert SameValue();
        if (_newValue == 0) revert ZeroValue();
        
        uint256 oldValue = value;
        value = _newValue;
        counter++;
        
        emit ValueUpdated(oldValue, _newValue, msg.sender);
    }
    
    function increment() external whenNotPaused {
        counter++;
        emit CounterIncremented(counter);
    }
    
    function pause() external onlyOwner {
        _pause();
    }
    
    function unpause() external onlyOwner {
        _unpause();
    }
    
    function getValue() external view returns (uint256) {
        return value;
    }
    
    function getCounter() external view returns (uint256) {
        return counter;
    }
}
EOF

