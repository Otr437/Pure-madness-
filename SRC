# =============================================
# DEPENDENCY INSTALLATION
# =============================================

install_all_dependencies() {
    echo -e "\n${YELLOW}╔═══════════════════════════════════════════════╗${NC}"
    echo -e "${YELLOW}║   DEPENDENCY INSTALLATION                     ║${NC}"
    echo -e "${YELLOW}╚═══════════════════════════════════════════════╝${NC}\n"
    
    # Node.js
    if ! command -v node &> /dev/null; then
        log_warning "Node.js not found"
        if ask_yes_no "Install Node.js via nvm?" "y"; then
            curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.7/install.sh | bash
            export NVM_DIR="$HOME/.nvm"
            [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
            nvm install --lts && nvm use --lts
            log_success "Node.js installed: $(node --version)"
        else
            log_error "Node.js is required. Exiting."
            exit 1
        fi
    else
        log_success "Node.js: $(node --version)"
    fi
    
    # zkApp CLI
    if ! command -v zk &> /dev/null; then
        if ask_yes_no "Install zkApp CLI for Mina?" "y"; then
            npm install -g zkapp-cli@latest
            log_success "zkApp CLI installed"
        else
            log_warning "zkApp CLI skipped (needed for Mina deployments)"
        fi
    else
        log_success "zkApp CLI: $(zk --version 2>/dev/null | head -1)"
    fi
    
    # Hardhat
    echo -e "\n${BLUE}=== Hardhat Setup ===${NC}"
    if ask_yes_no "Setup Hardhat environment?" "y"; then
        cd "$BASE_DIR/EVM/BUILD_ENV/hardhat"
        [ ! -f "package.json" ] && npm init -y 2>/dev/null
        
        log_info "Installing Hardhat packages..."
        npm install --save-dev \
            hardhat@latest \
            @nomicfoundation/hardhat-toolbox@latest \
            @nomicfoundation/hardhat-verify@latest \
            @openzeppelin/contracts@latest \
            ethers@latest \
            dotenv@latest 2>/dev/null
        
        log_success "Hardhat installed"
    else
        log_warning "Hardhat skipped"
    fi
    
    # Foundry
    echo -e "\n${BLUE}=== Foundry Setup ===${NC}"
    if ! command -v forge &> /dev/null; then
        if ask_yes_no "Install Foundry?" "y"; then
            log_info "Installing Foundry..."
            curl -L https://foundry.paradigm.xyz | bash
            export PATH="$HOME/.foundry/bin:$PATH"
            
            if [ -f "$HOME/.bashrc" ]; then
                source "$HOME/.bashrc" 2>/dev/null || true
            elif [ -f "$HOME/.zshrc" ]; then
                source "$HOME/.zshrc" 2>/dev/null || true
            fi
            
            foundryup 2>/dev/null || true
            log_success "Foundry installed"
        else
            log_warning "Foundry skipped"
        fi
    else
        log_success "Foundry: $(forge --version 2>/dev/null | head -1)"
    fi
    
    # Additional tools
    if ask_yes_no "Install additional tools (jq for JSON parsing)?" "y"; then
        if command -v apt-get &> /dev/null; then
            sudo apt-get update && sudo apt-get install -y jq 2>/dev/null || true
        elif command -v brew &> /dev/null; then
            brew install jq 2>/dev/null || true
        elif command -v yum &> /dev/null; then
            sudo yum install -y jq 2>/dev/null || true
        fi
        log_success "Additional tools installed"
    fi
    
    log_success "All dependencies installed"
}

