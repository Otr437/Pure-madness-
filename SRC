    paused.assertFalse();
    
    const hash = record.hash();
    this.recordHash.set(hash);
    
    const total = this.totalRecords.getAndRequireEquals();
    this.totalRecords.set(total.add(1));
  }

  @method async togglePause() {
    const owner = this.owner.getAndRequireEquals();
    const sender = this.sender.getAndRequireSignature();
    owner.equals(sender).assertTrue();
    
    const paused = this.paused.getAndRequireEquals();
    this.paused.set(paused.not());
  }
}
